rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users/{userId}/profile/{docId}
    // Fields: height (number), age (number), gender (string), customExercises (map)
    //
    // Collection: users/{userId}/dailyRecords/{date}
    // Fields: date (string), habits (map), calories (map), workoutStats (map),
    //         pilates (map), treadmill (map), body (map), noWorkout (bool), noCardio (bool)
    //
    // Collection: users/{userId}/workoutSets/{setId}
    // Fields: date (string), part (string), exercise (string), weight (number), reps (number), timestamp (number)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow read/write to user's own profile and subcollections
      match /profile/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /dailyRecords/{date} {
        allow read, write: if isOwner(userId);
      }
      match /workoutSets/{setId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
